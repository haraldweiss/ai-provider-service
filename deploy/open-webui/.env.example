# /opt/open-webui/.env — von beiden Quadlets (open-webui.container, litellm.container)
# per EnvironmentFile= eingelesen.
#
# Erzeugen mit:
#   sudo cp deploy/open-webui/.env.example /opt/open-webui/.env
#   sudo chmod 600 /opt/open-webui/.env
#   KEY=$(openssl rand -hex 32)
#   sudo sed -i "s/REPLACE_ME_SECRET_HEX_64/$(openssl rand -hex 32)/"  /opt/open-webui/.env
#   sudo sed -i "s/REPLACE_ME_MASTER_KEY/sk-$KEY/g"                    /opt/open-webui/.env
#   sudo vi /opt/open-webui/.env     # ANTHROPIC_API_KEY ergänzen

# Öffentliche URL (Mail-Links etc.)
WEBUI_URL=https://chat.wolfinisoftware.de

# Open-WebUI-Sitzungs-Secret
WEBUI_SECRET_KEY=REPLACE_ME_SECRET_HEX_64

# LiteLLM-Master-Key + identischer Wert als OPENAI_API_KEY für Open WebUI:
# Open WebUI nutzt OPENAI_API_KEY als Bearer-Token gegenüber LiteLLM.
# Beide Werte MÜSSEN identisch sein.
LITELLM_MASTER_KEY=REPLACE_ME_MASTER_KEY
OPENAI_API_KEY=REPLACE_ME_MASTER_KEY

# --- Provider-Key ---
ANTHROPIC_API_KEY=

# --- Postgres (LiteLLM Spend-Tracking) ---
# Passwort generieren mit: openssl rand -hex 24
# DATABASE_URL ist daraus zusammengesetzt — wenn du POSTGRES_PASSWORD änderst,
# muss DATABASE_URL den gleichen neuen Wert enthalten!
POSTGRES_PASSWORD=REPLACE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql://litellm:REPLACE_ME_POSTGRES_PASSWORD@postgres:5432/litellm
