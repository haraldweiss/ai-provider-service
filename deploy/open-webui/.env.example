# Öffentliche URL, unter der Open WebUI erreichbar ist (für Mail-Links etc.)
WEBUI_URL=https://chat.wolfinisoftware.de

# Open-WebUI-Sitzungs-Secret — einmalig erzeugen mit: openssl rand -hex 32
WEBUI_SECRET_KEY=REPLACE_ME_SECRET_HEX_64

# LiteLLM-Master-Key — schützt den Proxy intern und ist gleichzeitig der
# "API Key", den Open WebUI gegenüber LiteLLM benutzt.
# Erzeugen mit: openssl rand -hex 32 (mit Präfix "sk-" davor, sieht für Open WebUI
# nach einem normalen OpenAI-Key aus).
LITELLM_MASTER_KEY=sk-REPLACE_ME_LITELLM_MASTER_KEY

# --- Provider-Keys (nur die setzen, die du nutzt) ---

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI (leer lassen wenn nicht genutzt — dann auch in litellm-config.yaml
# den gpt-4o-Block entfernen, sonst loggt LiteLLM Warnungen)
OPENAI_API_KEY=

# Ollama (nur wenn lokal verfügbar; sonst weglassen)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
