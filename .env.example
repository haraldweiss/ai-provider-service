# Service-Konfiguration
PORT=8767
HOST=127.0.0.1

# Master-Key für Config-Encryption (Fernet-kompatibel, 32 Byte base64-encoded).
# Generieren mit: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=

# Service-Token für Konsumenten-Apps (Bearer-Auth).
# Generieren mit: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_TOKEN=

# CORS-Origins (komma-separiert), für Browser-direkt-Aufrufe (loganonymizer u.a.)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://bewerbungen.wolfinisoftware.de

# System-Provider Credentials (optional, falls zentral genutzt)
ANTHROPIC_API_KEY=
OLLAMA_URL=http://127.0.0.1:11434

# Allowlist für den ANTHROPIC_API_KEY (Server-Key) — comma-separierte user_ids.
# Leer / nicht gesetzt = offen für alle (single-tenant Default).
# Gesetzt: nur die genannten User dürfen den Server-Key nutzen, alle anderen
#         müssen unter /configs/<user_id>/claude einen eigenen Key konfigurieren.
CLAUDE_SERVER_KEY_ALLOWED_USERS=

# Storage
DATABASE_URL=sqlite:///storage.db

# Queue
QUEUE_TTL_HOURS=24
HEALTH_CHECK_INTERVAL_SEC=30
QUEUE_DRAIN_INTERVAL_SEC=60

# Access control (provider gating)
ADMIN_TOKEN=          # required for admin access; generate with: python -c "import secrets;print(secrets.token_urlsafe(32))"
ADMIN_USER_ID=harald  # principal.user_id assigned to admin token holders
UNGATED_PROVIDERS=ollama  # comma-separated; everything else needs a grant
GATE_ENABLED=false    # flip to true AFTER running `flask grants-bootstrap`

# opencode.ai provider
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Flask sessions (admin UI cookie)
SECRET_KEY=           # generate with: python -c "import secrets;print(secrets.token_urlsafe(32))"

# --- news-agent (täglicher Daily-Roundup, systemd-Timer) ---
# Primärer Provider + Modell. Haiku 4.5 ist der Cost-aware Default (~$0.15 / Lauf).
# Mit Sonnet 4.6 (~$1.66 / Lauf, also -90 % Kosten bei Wechsel zu Haiku):
#   NEWS_AGENT_MODEL_CLAUDE=claude-sonnet-4-6
NEWS_AGENT_PROVIDER=claude
NEWS_AGENT_MODEL_CLAUDE=claude-haiku-4-5-20251001

# Fallback wenn der Primär-Provider scheitert (z.B. Anthropic-Outage):
NEWS_AGENT_FALLBACK=ollama
NEWS_AGENT_MODEL_OLLAMA=qwen3.6:latest

# Max. Tool-Loop-Iterationen (Web-Search + Read + Generate)
NEWS_AGENT_MAX_ITERATIONS=40

# WordPress-Ziel
WORDPRESS_URL=
WORDPRESS_USER=news-agent
WORDPRESS_APP_PASSWORD=
WORDPRESS_CATEGORY=AI-News
